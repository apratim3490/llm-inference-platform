# LLM Inference Platform Configuration
# Copy this to .env and fill in your values

# ===================
# vLLM Configuration
# ===================
VLLM_BASE_URL=http://localhost:8001
VLLM_MODEL_NAME=mistralai/Mistral-7B-Instruct-v0.3
VLLM_TIMEOUT_SECONDS=90

# ===================
# Redis Configuration
# ===================
REDIS_URL=redis://localhost:6379/0

# ===================
# API Configuration
# ===================
API_HOST=0.0.0.0
API_PORT=8000
API_ENV=development
DEBUG=true

# ===================
# Rate Limiting
# ===================
RATE_LIMIT_FREE_RPM=10
RATE_LIMIT_FREE_TPM=10000
RATE_LIMIT_PRO_RPM=60
RATE_LIMIT_PRO_TPM=100000
RATE_LIMIT_ADMIN_RPM=300
RATE_LIMIT_ADMIN_TPM=1000000

# ===================
# Queue Configuration
# ===================
QUEUE_MAX_SIZE=100
QUEUE_MAX_CONCURRENT=8

# ===================
# Safety Filter
# ===================
SAFETY_ENABLED=true
SAFETY_ML_CLASSIFIER_ENABLED=false

# ===================
# Observability
# ===================
LOG_LEVEL=INFO
LOG_FORMAT=json
